# Harden the uploads directory: serve files only, never execute code.

Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Disallow direct access to hidden files.
  RewriteRule "(^|/)\." - [F,L]

  # Only allow the file types generated by api/upload.php.
  RewriteRule !\.(?:jpe?g|png|gif|webp|pdf)$ - [F,NC,L]
</IfModule>

# Prevent script execution and access to server-side templates/configs.
<FilesMatch "\.(?:php[0-9]?|phtml|phar|cgi|pl|py|sh|shtml|fcgi|asp|aspx|jsp)$">
  Require all denied
</FilesMatch>

<FilesMatch "\.(?:htaccess|htpasswd|ini|log|conf|env|json|lock|sql|yml|yaml)$">
  Require all denied
</FilesMatch>

<IfModule mod_php.c>
  php_flag engine off
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Content-Security-Policy "default-src 'none'; img-src 'self' data:; style-src 'none'; script-src 'none'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
  Header always set Cache-Control "public, max-age=2592000, immutable"
</IfModule>

<IfModule mod_mime.c>
  RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .php8
  RemoveType .php .phtml .php3 .php4 .php5 .php7 .php8
  AddType image/jpeg .jpg .jpeg
  AddType image/png .png
  AddType image/gif .gif
  AddType image/webp .webp
  AddType application/pdf .pdf
</IfModule>
